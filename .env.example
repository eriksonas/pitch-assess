# =========================================================================
# Frontend variables (Vite — anything prefixed with VITE_ is shipped to
# the browser). Do not put secret keys here.
# =========================================================================
# Local dev: http://127.0.0.1:8090
# Production: full public URL of your PocketBase deployment, e.g. https://pitch.example.com
# Vite bakes this into the frontend bundle at build time.
VITE_PB_URL=http://127.0.0.1:8090

# Optional analytics / placeholders left in for future use:
VITE_GA_MEASUREMENT_ID=your-google-analytics-id-here
VITE_ADSENSE_ID=your-adsense-id-here
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here

# =========================================================================
# Server-side variables (PocketBase reads these at runtime via $os.getenv).
#
# These do NOT have the VITE_ prefix, so Vite will NOT bundle them into
# the frontend. The pb_hooks/proxy.pb.js reads them at request time.
#
# Load them into PocketBase's environment by running:
#     ./start-pocketbase.sh
# which sources this file before launching the PocketBase binary.
#
# Get keys at:
#   - https://openrouter.ai/keys
#   - https://platform.openai.com/api-keys
# =========================================================================
OPENROUTER_API_KEY=replace-with-your-openrouter-key
OPENAI_API_KEY=replace-with-your-openai-key
